{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "@playwright/test"
    ]
  },
  "include": [
    "api/**/*.ts",
    "fixtures/**/*.ts",
    "playwright.config.ts",
    "pages/**/*.ts",
    "test-data/**/*.ts",
    "tests/**/*.ts"
  ]
}
